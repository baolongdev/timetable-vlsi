# Neon Postgres connection string (optional legacy seed)
# Example: postgres://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# MongoDB — nguồn đồng bộ chính (khoa, phân công, giảng viên)
# Atlas: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Tên database (mặc định: timetable-vlsi)
MONGODB_DB=timetable-vlsi

# Public site URL (used in metadata / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
